secrets.local.env
*.secrets.env
*.pem
*.key

# 本机私有配置（.mcp.json 常含本地凭据路径，用 .mcp.json.example 做模板）
.mcp.json
.claude/settings.local.json

# driver-builder 施工隔离 worktree（可选加装件，不纳入版本控制）
.worktrees/

